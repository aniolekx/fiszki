{% extends 'base_with_nav.html.twig' %}

{% block title %}Ustawienia Systemu{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item">
        <a href="{{ path('app_admin_dashboard') }}" class="text-decoration-none">
            <i class="bi bi-shield-lock-fill"></i> Panel Admin
        </a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">
        <i class="bi bi-gear"></i> Ustawienia
    </li>
{% endblock %}

{% block body_content %}
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">
            <i class="bi bi-gear-fill"></i> Ustawienia Systemu
        </h1>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <form method="post" action="{{ path('app_admin_settings_update') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('update-settings') }}">
        
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-primary bg-gradient text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-coin"></i> Ustawienia kredytów
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <label for="default_credits" class="form-label fw-semibold">
                                <i class="bi bi-person-plus"></i> Kredyty dla nowych użytkowników
                            </label>
                            <input type="number" class="form-control form-control-lg" 
                                   name="default_credits" id="default_credits" 
                                   value="{{ settings.default_credits }}" 
                                   min="0" max="10000" required>
                            <div class="form-text">
                                Liczba kredytów przyznawana automatycznie nowym użytkownikom przy rejestracji
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <label for="ai_generation_cost" class="form-label fw-semibold">
                                <i class="bi bi-magic"></i> Koszt generacji AI
                            </label>
                            <input type="number" class="form-control form-control-lg" 
                                   name="ai_generation_cost" id="ai_generation_cost" 
                                   value="{{ settings.ai_generation_cost }}" 
                                   min="1" max="1000" required>
                            <div class="form-text">
                                Liczba kredytów pobierana za jedną generację fiszek przez AI
                            </div>
                        </div>
                        
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> 
                            <strong>Wskazówka:</strong> Zalecane wartości to 500 kredytów początkowych i 100 za generację.
                            To pozwala nowym użytkownikom na 5 darmowych generacji.
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-info bg-gradient text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-cpu"></i> Limity OpenAI
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <label for="openai_monthly_limit" class="form-label fw-semibold">
                                <i class="bi bi-speedometer2"></i> Miesięczny limit tokenów
                            </label>
                            <input type="number" class="form-control form-control-lg" 
                                   name="openai_monthly_limit" id="openai_monthly_limit" 
                                   value="{{ settings.openai_monthly_limit }}" 
                                   min="1000" max="10000000" required>
                            <div class="form-text">
                                Maksymalna liczba tokenów OpenAI do wykorzystania w miesiącu
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-graph-up"></i> Aktualne zużycie
                            </label>
                            <div class="progress" style="height: 25px;">
                                {% set usage_percent = 0 %}
                                <div class="progress-bar bg-info" role="progressbar" 
                                     style="width: {{ usage_percent }}%"
                                     aria-valuenow="{{ usage_percent }}" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                    {{ usage_percent }}%
                                </div>
                            </div>
                            <div class="form-text">
                                Wykorzystano 0 z {{ settings.openai_monthly_limit|number_format(0, ',', ' ') }} tokenów
                            </div>
                        </div>
                        
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> 
                            <strong>Uwaga:</strong> Po przekroczeniu limitu generowanie fiszek przez AI zostanie tymczasowo wyłączone.
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row g-4 mt-2">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-secondary bg-gradient text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-toggles"></i> Opcje systemowe
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="maintenance_mode" 
                                   name="maintenance_mode" value="1"
                                   {% if settings.maintenance_mode %}checked{% endif %}>
                            <label class="form-check-label" for="maintenance_mode">
                                <strong>Tryb konserwacji</strong>
                                <br>
                                <small class="text-muted">Wyłącza dostęp do aplikacji dla zwykłych użytkowników</small>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mt-4">
            <div class="col-12">
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Powrót
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-save"></i> Zapisz ustawienia
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>
{% endblock %}