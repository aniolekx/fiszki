{% extends 'base_with_nav.html.twig' %}

{% block title %}Użytkownik: {{ user.email }}{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item">
        <a href="{{ path('app_admin_dashboard') }}" class="text-decoration-none">
            <i class="bi bi-shield-lock-fill"></i> Panel Admin
        </a>
    </li>
    <li class="breadcrumb-item">
        <a href="{{ path('app_admin_users') }}" class="text-decoration-none">
            <i class="bi bi-people"></i> Użytkownicy
        </a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">
        {{ user.email }}
    </li>
{% endblock %}

{% block body_content %}
<div class="container-fluid px-4">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <div class="bg-primary bg-gradient rounded-circle d-inline-flex align-items-center justify-content-center" 
                             style="width: 80px; height: 80px;">
                            <i class="bi bi-person-fill text-white fs-1"></i>
                        </div>
                    </div>
                    <h4 class="mb-1">{{ user.email }}</h4>
                    <p class="text-muted mb-3">ID: #{{ user.id }}</p>
                    
                    <div class="mb-3">
                        {% if user.isConfirmed %}
                            <span class="badge bg-success">
                                <i class="bi bi-check-circle"></i> Email potwierdzony
                            </span>
                        {% else %}
                            <span class="badge bg-warning">
                                <i class="bi bi-hourglass"></i> Email niepotwierdzony
                            </span>
                        {% endif %}
                        
                        {% if user.isAdmin %}
                            <span class="badge bg-danger ms-1">
                                <i class="bi bi-shield-fill"></i> Administrator
                            </span>
                        {% endif %}
                    </div>
                    
                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addCreditsModal">
                            <i class="bi bi-plus-circle"></i> Dodaj kredyty
                        </button>
                        
                        {% if user != app.user %}
                            <form method="post" action="{{ path('app_admin_user_toggle_admin', {'id': user.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle-admin' ~ user.id) }}">
                                {% if user.isAdmin %}
                                    <button type="submit" class="btn btn-warning w-100" 
                                            onclick="return confirm('Czy na pewno chcesz usunąć uprawnienia administratora?')">
                                        <i class="bi bi-shield-x"></i> Usuń admina
                                    </button>
                                {% else %}
                                    <button type="submit" class="btn btn-danger w-100"
                                            onclick="return confirm('Czy na pewno chcesz nadać uprawnienia administratora?')">
                                        <i class="bi bi-shield-plus"></i> Nadaj admina
                                    </button>
                                {% endif %}
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <h5 class="card-title">Stan kredytów</h5>
                    {% if credits %}
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>Saldo</span>
                                <h3 class="mb-0 {% if credits.balance < 100 %}text-danger{% else %}text-success{% endif %}">
                                    {{ credits.balance }}
                                </h3>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar {% if credits.balance < 100 %}bg-danger{% elseif credits.balance < 500 %}bg-warning{% else %}bg-success{% endif %}" 
                                     role="progressbar" 
                                     style="width: {{ (credits.balance / 1000 * 100)|round }}%"
                                     aria-valuenow="{{ credits.balance }}" 
                                     aria-valuemin="0" 
                                     aria-valuemax="1000">
                                </div>
                            </div>
                        </div>
                        
                        <div class="row text-center">
                            <div class="col-6">
                                <small class="text-muted d-block">Otrzymane</small>
                                <strong class="text-success">{{ credits.totalEarned }}</strong>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Wydane</small>
                                <strong class="text-danger">{{ credits.totalSpent }}</strong>
                            </div>
                        </div>
                    {% else %}
                        <p class="text-muted mb-0">Brak danych o kredytach</p>
                    {% endif %}
                </div>
            </div>
            
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <h5 class="card-title">Statystyki AI</h5>
                    <div class="mb-2">
                        <div class="d-flex justify-content-between">
                            <span>Tokeny użyte</span>
                            <strong>{{ tokens_used|number_format(0, ',', ' ') }}</strong>
                        </div>
                    </div>
                    <small class="text-muted">Szacowany koszt: ${{ (tokens_used * 0.000002)|number_format(4) }}</small>
                </div>
            </div>
        </div>
        
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 pb-3">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history"></i> Historia transakcji kredytowych
                    </h5>
                </div>
                <div class="card-body">
                    {% if transactions|length > 0 %}
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Data</th>
                                        <th>Typ</th>
                                        <th>Opis</th>
                                        <th class="text-end">Kwota</th>
                                        <th class="text-end">Saldo po</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for transaction in transactions %}
                                        <tr>
                                            <td>
                                                <small>{{ transaction.createdAt|date('d.m.Y H:i') }}</small>
                                            </td>
                                            <td>
                                                {% if transaction.type == 'initial' %}
                                                    <span class="badge bg-primary">Początkowe</span>
                                                {% elseif transaction.type == 'admin_grant' %}
                                                    <span class="badge bg-success">Admin</span>
                                                {% elseif transaction.type == 'ai_generation' %}
                                                    <span class="badge bg-info">Generacja AI</span>
                                                {% elseif transaction.type == 'refund' %}
                                                    <span class="badge bg-warning">Zwrot</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">{{ transaction.type }}</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {{ transaction.description|default('-') }}
                                                {% if transaction.performedBy %}
                                                    <br>
                                                    <small class="text-muted">przez: {{ transaction.performedBy.email }}</small>
                                                {% endif %}
                                            </td>
                                            <td class="text-end">
                                                {% if transaction.amount > 0 %}
                                                    <span class="text-success fw-semibold">+{{ transaction.amount }}</span>
                                                {% else %}
                                                    <span class="text-danger fw-semibold">{{ transaction.amount }}</span>
                                                {% endif %}
                                            </td>
                                            <td class="text-end">
                                                <strong>{{ transaction.balanceAfter }}</strong>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-muted text-center py-4">Brak historii transakcji</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addCreditsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Dodaj kredyty dla {{ user.email }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="{{ path('app_admin_user_add_credits', {'id': user.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('add-credits' ~ user.id) }}">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="amount" class="form-label">Liczba kredytów</label>
                        <input type="number" class="form-control form-control-lg" name="amount" id="amount" 
                               value="500" min="1" max="10000" required>
                        <div class="form-text">Wprowadź liczbę kredytów do dodania (1-10000)</div>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Opis</label>
                        <input type="text" class="form-control" name="description" id="description" 
                               placeholder="Np. Bonus za aktywność, Kompensata za błąd"
                               value="Kredyty dodane przez administratora">
                        <div class="form-text">Opcjonalny opis transakcji</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Dodaj kredyty
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}