{% extends 'base_with_nav.html.twig' %}

{% block title %}Zarządzanie Użytkownikami{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item">
        <a href="{{ path('app_admin_dashboard') }}" class="text-decoration-none">
            <i class="bi bi-shield-lock-fill"></i> Panel Admin
        </a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">
        <i class="bi bi-people"></i> Użytkownicy
    </li>
{% endblock %}

{% block body_content %}
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">
            <i class="bi bi-people-fill"></i> Zarządzanie Użytkownikami
        </h1>
        <div>
            <span class="badge bg-primary fs-6">{{ users_data|length }} użytkowników</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th>Rola</th>
                            <th class="text-center">Kredyty</th>
                            <th class="text-center">Tokeny użyte</th>
                            <th>Data rejestracji</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for data in users_data %}
                            <tr>
                                <td>{{ data.user.id }}</td>
                                <td>
                                    <a href="{{ path('app_admin_user_show', {'id': data.user.id}) }}" 
                                       class="text-decoration-none fw-semibold">
                                        {{ data.user.email }}
                                    </a>
                                </td>
                                <td>
                                    {% if data.user.isConfirmed %}
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Potwierdzony
                                        </span>
                                    {% else %}
                                        <span class="badge bg-warning">
                                            <i class="bi bi-hourglass"></i> Niepotwierdzony
                                        </span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if data.user.isAdmin %}
                                        <span class="badge bg-danger">
                                            <i class="bi bi-shield-fill"></i> Admin
                                        </span>
                                    {% else %}
                                        <span class="badge bg-secondary">Użytkownik</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {% if data.credits %}
                                        {% if data.credits.balance < 100 %}
                                            <span class="badge bg-danger">{{ data.credits.balance }}</span>
                                        {% elseif data.credits.balance < 500 %}
                                            <span class="badge bg-warning">{{ data.credits.balance }}</span>
                                        {% else %}
                                            <span class="badge bg-success">{{ data.credits.balance }}</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="badge bg-secondary">0</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {% if data.tokens_used > 0 %}
                                        <span class="text-muted">{{ data.tokens_used|number_format(0, ',', ' ') }}</span>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if data.user.createdAt %}
                                        <small>{{ data.user.createdAt|date('d.m.Y H:i') }}</small>
                                    {% else %}
                                        <small class="text-muted">-</small>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="{{ path('app_admin_user_show', {'id': data.user.id}) }}" 
                                           class="btn btn-outline-primary" 
                                           title="Szczegóły" 
                                           data-bs-toggle="tooltip">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        {% if data.credits and data.credits.balance < 100 %}
                                            <button type="button" 
                                                    class="btn btn-outline-success quick-add-credits" 
                                                    data-user-id="{{ data.user.id }}"
                                                    data-user-email="{{ data.user.email }}"
                                                    title="Doładuj kredyty" 
                                                    data-bs-toggle="tooltip">
                                                <i class="bi bi-plus-circle"></i>
                                            </button>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="quickAddCreditsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Doładuj kredyty</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" id="quickAddCreditsForm">
                <div class="modal-body">
                    <p>Użytkownik: <strong id="modalUserEmail"></strong></p>
                    <div class="mb-3">
                        <label for="creditAmount" class="form-label">Liczba kredytów</label>
                        <input type="number" class="form-control" name="amount" id="creditAmount" 
                               value="500" min="1" max="10000" required>
                    </div>
                    <div class="mb-3">
                        <label for="creditDescription" class="form-label">Opis (opcjonalnie)</label>
                        <input type="text" class="form-control" name="description" id="creditDescription" 
                               placeholder="Np. Bonus za aktywność">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Dodaj kredyty
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function(tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
    
    const modal = new bootstrap.Modal(document.getElementById('quickAddCreditsModal'));
    const form = document.getElementById('quickAddCreditsForm');
    const modalUserEmail = document.getElementById('modalUserEmail');
    
    document.querySelectorAll('.quick-add-credits').forEach(button => {
        button.addEventListener('click', function() {
            const userId = this.dataset.userId;
            const userEmail = this.dataset.userEmail;
            
            modalUserEmail.textContent = userEmail;
            form.action = `/admin/users/${userId}/add-credits`;
            
            modal.show();
        });
    });
});
</script>
{% endblock %}