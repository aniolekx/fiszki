{% extends 'base_with_nav.html.twig' %}

{% block title %}Szczegóły talii{% endblock %}

{% block body_content %}
    <div class="container mt-4">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h1 class="h3 mb-0">{{ deck.name }}</h1>
                        <div class="btn-group" role="group">
                            <a href="{{ path('deck_edit', {'id': deck.id}) }}" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edytuj
                            </a>
                            <form action="{{ path('deck_delete', {'id': deck.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć tę talię?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ deck.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Usuń
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h5>Informacje o talii</h5>
                                <p class="mb-1"><strong>Data utworzenia:</strong> {{ deck.createdAt|date('d.m.Y H:i') }}</p>
                                <p class="mb-1"><strong>Ostatnia modyfikacja:</strong> {{ deck.updatedAt|date('d.m.Y H:i') }}</p>
                                <p class="mb-1"><strong>Liczba fiszek:</strong> {{ deck.flashcards|length }}</p>
                            </div>
                        </div>

                        <h5 class="mb-3">Fiszki w talii</h5>
                        {% if deck.flashcards|length > 0 %}
                            <div class="list-group">
                                {% for flashcard in deck.flashcards %}
                                    <div class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-1">{{ flashcard.front }}</h6>
                                                <p class="mb-0 text-muted">{{ flashcard.back }}</p>
                                            </div>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="{{ path('flashcard_edit', {'id': flashcard.id}) }}" class="btn btn-outline-secondary" title="Edytuj" data-bs-toggle="tooltip">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form action="{{ path('flashcard_delete', {'id': flashcard.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć tę fiszkę?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ flashcard.id) }}">
                                                    <button type="submit" class="btn btn-outline-danger" title="Usuń" data-bs-toggle="tooltip">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <p class="text-muted">Ta talia nie zawiera jeszcze żadnych fiszek.</p>
                        {% endif %}

                        <div class="mt-4">
                            <a href="{{ path('flashcard_new') }}" class="btn btn-success">
                                <i class="bi bi-plus-circle"></i> Dodaj fiszkę
                            </a>
                            <a href="{{ path('deck_index') }}" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Powrót do listy
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function(tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    });
    </script>
{% endblock %}
