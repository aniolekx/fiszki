{% extends 'base_with_nav.html.twig' %}

{% block title %}Nowa talia{% endblock %}

{% block body_content %}
    <div class="container mt-4">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="card">
                    <div class="card-header">
                        <h1 class="h3 mb-0">Tworzenie nowej talii</h1>
                    </div>
                    <div class="card-body">
                        {% if form.vars.errors|length > 0 %}
                            <div class="alert alert-danger">
                                {{ form_errors(form) }}
                            </div>
                        {% endif %}
                        {{ form_start(form) }}
                            <div class="mb-3">
                                {{ form_label(form.name, 'Nazwa talii') }}
                                {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Wprowadź nazwę talii'}}) }}
                                {{ form_errors(form.name) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.description, 'Opis') }}
                                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Wprowadź opis talii'}}) }}
                                {{ form_errors(form.description) }}
                            </div>
                            <div class="d-flex justify-content-between">
                                <a href="{{ path('deck_index') }}" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left"></i> Powrót do listy
                                </a>
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-plus"></i> Utwórz talię
                                </button>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
