{% extends 'base_with_nav.html.twig' %}

{% block title %}Moje talie{% endblock %}

{% block body_content %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Moje talie</h1>
            <a href="{{ path('deck_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Nowa talia
            </a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                {{ message }}
            </div>
        {% endfor %}

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Nazwa talii</th>
                                <th>Liczba fiszek</th>
                                <th>Data utworzenia</th>
                                <th>Ostatnia modyfikacja</th>
                                <th class="text-end">Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for deck in decks %}
                            <tr>
                                <td>
                                    <a href="{{ path('deck_show', {'id': deck.id}) }}" class="text-decoration-none">
                                        {{ deck.name }}
                                    </a>
                                </td>
                                <td>{{ deck.flashcards|length }}</td>
                                <td>{{ deck.createdAt|date('d.m.Y H:i') }}</td>
                                <td>{{ deck.updatedAt|date('d.m.Y H:i') }}</td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a href="{{ path('deck_show', {'id': deck.id}) }}" class="btn btn-sm btn-outline-primary" title="Pokaż">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('deck_edit', {'id': deck.id}) }}" class="btn btn-sm btn-outline-secondary" title="Edytuj">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form action="{{ path('deck_delete', {'id': deck.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć tę talię?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ deck.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Usuń">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-4">
                                    <p class="text-muted mb-0">Nie masz jeszcze żadnych talii.</p>
                                    <a href="{{ path('deck_new') }}" class="btn btn-primary mt-3">Utwórz pierwszą talię</a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
