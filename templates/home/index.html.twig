{% extends 'base_with_nav.html.twig' %}

 {% block title %}Strona główna{% endblock %}

{% block body_content %}
    <!-- Hero Section -->
    <section class="py-5 text-center">
        <div class="container">
             <h1 class="display-4 mb-3">Witaj w aplikacji Fiszki!</h1>
             <p class="lead">Twoje rozwiązanie do nauki i zapamiętywania nowych informacji.</p>
             <a href="#features" class="btn btn-primary btn-lg mt-3">Dowiedz się więcej</a>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-5">
        <div class="container">
             <h2 class="text-center mb-4">Główne funkcje</h2>
            <div class="row text-center">
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                             <h5 class="card-title">Karty do nauki</h5>
                             <p class="card-text">Twórz i studiuj karty do nauki, aby skutecznie zapamiętywać informacje.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                             <h5 class="card-title">Testy</h5>
                             <p class="card-text">Sprawdź swoją wiedzę za pomocą interaktywnych testów.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                             <h5 class="card-title">Śledzenie postępów</h5>
                             <p class="card-text">Śledź swoje postępy w nauce i ustaw cele.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Call to Action Section -->
    <section class="bg-light py-5">
        <div class="container text-center">
             <h2 class="mb-3">Gotowy do rozpoczęcia nauki?</h2>
             <p class="lead mb-4">Zarejestruj się dziś i podjęć pierwszy krok w kierunku opanowania nowych informacji.</p>
            <a href="#signup" class="btn btn-success btn-lg">Zacznij teraz</a>
            {% if not app.user %}
                <a href="{{ path('app_register') }}" class="btn btn-outline-primary btn-lg ms-2">Zarejestruj się</a>
            {% endif %}
        </div>
    </section>

    <!-- Sample Cards Section -->
    <section class="py-5">
        <div class="container">
             <h2 class="text-center mb-4">Dlaczego warto stosować fiszki?</h2>
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                              <h5 class="card-title">Efektywna nauka</h5>
                              <p class="card-text">Fiszki pomagają w skutecznej nauce i zapamiętywaniu informacji.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                              <h5 class="card-title">Lepsze zapamiętywanie</h5>
                              <p class="card-text">Używanie fiszek poprawia zdolność do zapamiętywania i przypominania informacji.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                              <h5 class="card-title">Elastyczność nauki</h5>
                              <p class="card-text">Fiszki mogą być używane w dowolnym miejscu i czasie, co ułatwia naukę.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock body_content %}
