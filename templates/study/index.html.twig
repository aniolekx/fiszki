{% extends 'base_with_nav.html.twig' %}

{% block title %}Sesja nauki - Fiszki{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">
        <i class="bi bi-mortarboard-fill"></i> Sesja nauki
    </li>
{% endblock %}

{% block body_content %}
    <h1 class="mb-4">Sesja nauki</h1>

    {% if deckStats is empty %}
        <div class="alert alert-info">
            <h4 class="alert-heading">Brak talii do nauki</h4>
            <p>Nie masz jeszcze żadnych talii z fiszkami. Utwórz swoją pierwszą talię, aby rozpocząć naukę!</p>
            <hr>
            <a href="{{ path('deck_new') }}" class="btn btn-primary">Utwórz nową talię</a>
        </div>
    {% else %}
        <div class="row">
            {% for stat in deckStats %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ stat.deck.name }}</h5>
                            <p class="card-text text-muted">{{ stat.deck.description|default('Brak opisu') }}</p>
                            
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Wszystkie fiszki:</span>
                                    <span class="badge bg-secondary">{{ stat.totalCards }}</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Do powtórki:</span>
                                    <span class="badge bg-warning text-dark">{{ stat.dueCards }}</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span>Nowe:</span>
                                    <span class="badge bg-success">{{ stat.newCards }}</span>
                                </div>
                            </div>

                            {% if stat.dueCards > 0 or stat.newCards > 0 %}
                                <a href="{{ path('app_study_start', {'id': stat.deck.id}) }}" class="btn btn-primary w-100">
                                    <i class="bi bi-play-fill"></i> Rozpocznij naukę
                                </a>
                            {% else %}
                                <button class="btn btn-secondary w-100" disabled>
                                    <i class="bi bi-check-circle"></i> Brak fiszek do powtórki
                                </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {% if recentSessions is not empty %}
        <h2 class="mt-5 mb-3">Ostatnie sesje nauki</h2>
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Talia</th>
                        <th>Przejrzane</th>
                        <th>Poprawne</th>
                        <th>Skuteczność</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for session in recentSessions %}
                        <tr>
                            <td>{{ session.startedAt|date('Y-m-d H:i') }}</td>
                            <td>{{ session.deck.name }}</td>
                            <td>{{ session.reviewedCards }}/{{ session.totalCards }}</td>
                            <td>{{ session.correctAnswers }}</td>
                            <td>
                                {% if session.reviewedCards > 0 %}
                                    <span class="badge bg-{{ session.accuracy >= 80 ? 'success' : (session.accuracy >= 60 ? 'warning text-dark' : 'danger') }}">
                                        {{ session.accuracy }}%
                                    </span>
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td>
                                {% if session.status == 'completed' %}
                                    <span class="badge bg-success">Ukończona</span>
                                {% elseif session.status == 'in_progress' %}
                                    <span class="badge bg-warning text-dark">W trakcie</span>
                                {% else %}
                                    <span class="badge bg-secondary">Porzucona</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        
        <div class="mt-3">
            <a href="{{ path('app_study_history') }}" class="btn btn-outline-primary">
                <i class="bi bi-clock-history"></i> Zobacz pełną historię
            </a>
        </div>
    {% endif %}
{% endblock %}