{% extends 'base_with_nav.html.twig' %}

{% block title %}Panel główny{% endblock %}

{% block breadcrumb_items %}
    <li class="breadcrumb-item active" aria-current="page">
        <i class="bi bi-speedometer2"></i> Dashboard
    </li>
{% endblock %}

{% block body_content %}
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-1">Panel główny</h1>
            <p class="text-muted mb-0">Witaj ponownie, {{ app.user.userIdentifier }}!</p>
        </div>
        <div class="d-none d-md-block">
            <span class="text-muted">{{ "now"|date('l, d F Y') }}</span>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-primary bg-gradient rounded-circle p-3">
                                <i class="bi bi-collection-fill text-white fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="mb-0">{{ total_decks }}</h3>
                            <p class="text-muted mb-0">Talii kart</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-success bg-gradient rounded-circle p-3">
                                <i class="bi bi-card-text text-white fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="mb-0">{{ total_flashcards }}</h3>
                            <p class="text-muted mb-0">Fiszek</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-info bg-gradient rounded-circle p-3">
                                <i class="bi bi-mortarboard-fill text-white fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="mb-0">0</h3>
                            <p class="text-muted mb-0">Sesji nauki</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-warning bg-gradient rounded-circle p-3">
                                <i class="bi bi-lightning-fill text-white fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="mb-0">0</h3>
                            <p class="text-muted mb-0">Do przejrzenia</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-4 pb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0">Twoje talie</h5>
                            <p class="text-muted small mb-0">Zarządzaj swoimi kolekcjami fiszek</p>
                        </div>
                        <a href="{{ path('deck_new') }}" class="btn btn-primary btn-sm">
                            <i class="bi bi-plus-circle"></i> Nowa
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    {% if decks|length > 0 %}
                        <div class="list-group list-group-flush">
                            {% for deck in decks|slice(0, 5) %}
                                <a href="{{ path('deck_show', {'id': deck.id}) }}" 
                                   class="list-group-item list-group-item-action border-0 px-0 py-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">{{ deck.name }}</h6>
                                            <small class="text-muted">
                                                <i class="bi bi-card-text"></i> {{ deck.flashcards|length }} fiszek
                                            </small>
                                        </div>
                                        <i class="bi bi-chevron-right text-muted"></i>
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                        {% if decks|length > 5 %}
                            <div class="text-center mt-3">
                                <a href="{{ path('deck_index') }}" class="btn btn-outline-primary btn-sm">
                                    Zobacz wszystkie ({{ decks|length }})
                                </a>
                            </div>
                        {% endif %}
                    {% else %}
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-muted display-1"></i>
                            <p class="text-muted mt-3">Nie masz jeszcze żadnych talii</p>
                            <a href="{{ path('deck_new') }}" class="btn btn-primary">
                                <i class="bi bi-plus-circle"></i> Utwórz pierwszą talię
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-4 pb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0">Ostatnie fiszki</h5>
                            <p class="text-muted small mb-0">Twoje najnowsze karty do nauki</p>
                        </div>
                        <a href="{{ path('flashcard_new') }}" class="btn btn-success btn-sm">
                            <i class="bi bi-plus-circle"></i> Nowa
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    {% if flashcards|length > 0 %}
                        <div class="list-group list-group-flush">
                            {% for flashcard in flashcards|slice(0, 5) %}
                                <div class="list-group-item border-0 px-0 py-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center mb-2">
                                                <span class="badge bg-primary bg-gradient me-2">Przód</span>
                                                <span class="fw-semibold">{{ flashcard.front|slice(0, 50) }}{% if flashcard.front|length > 50 %}...{% endif %}</span>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <span class="badge bg-secondary bg-gradient me-2">Tył</span>
                                                <span class="text-muted">{{ flashcard.back|slice(0, 50) }}{% if flashcard.back|length > 50 %}...{% endif %}</span>
                                            </div>
                                        </div>
                                        <a href="{{ path('flashcard_edit', {'id': flashcard.id}) }}" 
                                           class="btn btn-sm btn-outline-secondary ms-3">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        {% if flashcards|length > 5 %}
                            <div class="text-center mt-3">
                                <a href="{{ path('flashcard_index') }}" class="btn btn-outline-success btn-sm">
                                    Zobacz wszystkie ({{ flashcards|length }})
                                </a>
                            </div>
                        {% endif %}
                    {% else %}
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-muted display-1"></i>
                            <p class="text-muted mt-3">Nie masz jeszcze żadnych fiszek</p>
                            <a href="{{ path('flashcard_new') }}" class="btn btn-success">
                                <i class="bi bi-plus-circle"></i> Utwórz pierwszą fiszkę
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-5">
                    <h4 class="mb-3">Szybkie akcje</h4>
                    <div class="d-flex flex-wrap justify-content-center gap-3">
                        <a href="{{ path('app_study_index') }}" class="btn btn-lg btn-primary">
                            <i class="bi bi-mortarboard-fill me-2"></i> Rozpocznij naukę
                        </a>
                        <a href="{{ path('app_ai_generate') }}" class="btn btn-lg btn-outline-primary">
                            <i class="bi bi-magic me-2"></i> Generuj z AI
                        </a>
                        <a href="{{ path('deck_new') }}" class="btn btn-lg btn-outline-secondary">
                            <i class="bi bi-plus-circle me-2"></i> Nowa talia
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %} 