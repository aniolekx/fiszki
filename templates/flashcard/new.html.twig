{% extends 'base_with_nav.html.twig' %}

{% block title %}New Flashcard{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Create New Flashcard</h1>

        {{ form_start(form) }}
            <div class="mb-3">
                {{ form_row(form.front) }}
            </div>
            <div class="mb-3">
                {{ form_row(form.back) }}
            </div>
            <button type="submit" class="btn btn-success">Create</button>
        {{ form_end(form) }}

        <a href="{{ path('flashcard_index') }}" class="btn btn-secondary mt-3">Back to list</a>
    </div>
{% endblock %}
