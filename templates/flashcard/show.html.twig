{% extends 'base_with_nav.html.twig' %}

{% block title %}Flashcard Details{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Flashcard Details</h1>

        <div class="mb-3">
            <strong>Front:</strong>
            {{ flashcard.front }}
        </div>
        <div class="mb-3">
            <strong>Back:</strong>
            {{ flashcard.back }}
        </div>

        <a href="{{ path('flashcard_edit', {'id': flashcard.id}) }}" class="btn btn-primary">Edit</a>
        <a href="{{ path('flashcard_index') }}" class="btn btn-secondary">Back to list</a>
    </div>
{% endblock %}
