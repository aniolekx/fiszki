{% extends 'base_with_nav.html.twig' %}

{% block title %}Szczegóły fiszki{% endblock %}

{% block body_content %}
    <div class="container mt-4">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h1 class="h3 mb-0">Szczegóły fiszki</h1>
                        <div class="btn-group" role="group">
                            <a href="{{ path('flashcard_edit', {'id': flashcard.id}) }}" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edytuj
                            </a>
                            <form action="{{ path('flashcard_delete', {'id': flashcard.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć tę fiszkę?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ flashcard.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Usuń
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <h5 class="text-muted">Przód</h5>
                            <p class="fs-5">{{ flashcard.front }}</p>
                        </div>
                        <hr>
                        <div class="mb-4">
                            <h5 class="text-muted">Tył</h5>
                            <p class="fs-5">{{ flashcard.back }}</p>
                        </div>
                        {% if flashcard.deck %}
                        <hr>
                        <div class="mb-3">
                            <small class="text-muted">
                                <i class="bi bi-collection"></i> Talia: 
                                <a href="{{ path('deck_show', {'id': flashcard.deck.id}) }}">{{ flashcard.deck.name }}</a>
                            </small>
                        </div>
                        {% endif %}
                    </div>
                    <div class="card-footer">
                        <a href="{{ path('flashcard_index') }}" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Powrót do listy
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
