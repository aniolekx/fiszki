{% extends 'base_with_nav.html.twig' %}

{% block title %}Moje fiszki{% endblock %}

{% block body_content %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Moje fiszki</h1>
            <a href="{{ path('flashcard_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Nowa fiszka
            </a>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Przód</th>
                                <th>Tył</th>
                                <th class="text-end">Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for flashcard in flashcards %}
                            <tr>
                                <td>{{ flashcard.front }}</td>
                                <td>{{ flashcard.back }}</td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a href="{{ path('flashcard_show', {'id': flashcard.id}) }}" class="btn btn-sm btn-outline-primary" title="Pokaż">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('flashcard_edit', {'id': flashcard.id}) }}" class="btn btn-sm btn-outline-secondary" title="Edytuj">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form action="{{ path('flashcard_delete', {'id': flashcard.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć tę fiszkę?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ flashcard.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Usuń">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="3" class="text-center py-4">
                                    <p class="text-muted mb-0">Nie masz jeszcze żadnych fiszek.</p>
                                    <a href="{{ path('flashcard_new') }}" class="btn btn-primary mt-3">Utwórz pierwszą fiszkę</a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
